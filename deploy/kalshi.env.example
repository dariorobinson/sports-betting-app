# Copy this to /etc/kalshi-sports-betting/kalshi.env on the EC2 box, fill in real values, then:
#   chmod 600 /etc/kalshi-sports-betting/kalshi.env
#   chown kalshi:kalshi /etc/kalshi-sports-betting/kalshi.env
# Never commit the filled-in version anywhere.

KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=/etc/kalshi-sports-betting/kalshi_private_key.pem

# Start on demo until you've confirmed everything works end-to-end, then switch to prod:
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
# KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Required for this deployment — this app's own REST API must not be wide open on a real server.
APP_API_KEY=generate-a-long-random-value-here

# Leave this on loopback — nothing external needs to reach the REST API directly; the Discord bot
# runs in this same process and talks to the Kalshi services in-process, not over HTTP.
SERVER_ADDRESS=127.0.0.1
PORT=8080

# Discord bot (runs in-process — see discord/ and orchestrator/ packages). Omit DISCORD_BOT_TOKEN
# to run without the Discord bot at all; the REST API works fine either way.
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_AUTHORIZED_USER_ID=your-discord-user-id
ANTHROPIC_API_KEY=your-anthropic-api-key
